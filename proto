<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VMS Prototype | Waleed Ali</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Tajawal', sans-serif; background-color: #f8fafc; }
        .sidebar-link.active { background-color: #1e293b; color: white; border-right: 4px solid #3b82f6; }
        .page { display: none; }
        .page.active { display: block; animation: fadeIn 0.3s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <aside class="w-64 bg-slate-900 text-slate-300 flex-shrink-0 hidden md:flex flex-col">
        <div class="p-6 text-white font-bold text-2xl border-b border-slate-800 flex items-center gap-2">
            <div class="w-8 h-8 bg-blue-600 rounded flex items-center justify-center text-sm">V</div>
            VMS System
        </div>
        <nav class="flex-1 p-4 space-y-2 mt-4">
            <a href="javascript:void(0)" onclick="showPage('dashboard')" id="link-dashboard" class="sidebar-link active flex items-center p-3 rounded-lg transition">
                <span>📊 لوحة التحكم</span>
            </a>
            <a href="javascript:void(0)" onclick="showPage('visitors')" id="link-visitors" class="sidebar-link flex items-center p-3 rounded-lg transition hover:bg-slate-800">
                <span>👥 إدارة الزوار</span>
            </a>
            <a href="javascript:void(0)" onclick="showPage('new-visit')" id="link-new-visit" class="sidebar-link flex items-center p-3 rounded-lg transition hover:bg-slate-800">
                <span>➕ إصدار زيارة</span>
            </a>
        </nav>
        <div class="p-4 border-t border-slate-800 text-xs text-center">
            تطوير المهندس وليد علي &copy; 2026
        </div>
    </aside>

    <main class="flex-1 flex flex-col overflow-y-auto">
        <header class="bg-white shadow-sm p-4 flex justify-between items-center px-8">
            <h2 id="page-title" class="text-xl font-bold text-slate-800">لوحة التحكم</h2>
            <div class="flex items-center gap-4">
                <span class="text-sm text-slate-500">مرحباً، مسئول النظام</span>
                <div class="w-10 h-10 bg-slate-200 rounded-full border"></div>
            </div>
        </header>

        <div class="p-8">
            
            <div id="page-dashboard" class="page active">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div class="bg-white p-6 rounded-xl shadow-sm border-b-4 border-blue-500">
                        <p class="text-slate-500 text-sm">إجمالي الزوار</p>
                        <h3 class="text-3xl font-bold mt-2">1,254</h3>
                    </div>
                    <div class="bg-white p-6 rounded-xl shadow-sm border-b-4 border-green-500">
                        <p class="text-slate-500 text-sm">زيارات نشطة حالياً</p>
                        <h3 class="text-3xl font-bold mt-2">42</h3>
                    </div>
                    <div class="bg-white p-6 rounded-xl shadow-sm border-b-4 border-red-500">
                        <p class="text-slate-500 text-sm">محاولات دخول محظورة</p>
                        <h3 class="text-3xl font-bold mt-2">12</h3>
                    </div>
                </div>
                <div class="bg-white p-6 rounded-xl shadow-sm">
                    <h4 class="font-bold mb-4">آخر الزيارات المسجلة</h4>
                    <table class="w-full text-right">
                        <thead>
                            <tr class="text-slate-400 border-b">
                                <th class="pb-3">الزائر</th>
                                <th class="pb-3">النزيل</th>
                                <th class="pb-3">الوقت</th>
                                <th class="pb-3">الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b">
                                <td class="py-4">أحمد محمد علي</td>
                                <td>وليد علي</td>
                                <td>10:30 AM</td>
                                <td><span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">داخل المنشأة</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="page-visitors" class="page">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-2xl font-bold text-slate-800">قائمة الزوار المسجلين</h3>
                    <button class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm">+ إضافة زائر جديد</button>
                </div>
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <table class="w-full text-right">
                        <tr class="bg-slate-50 p-4 border-b">
                            <th class="p-4">الاسم</th>
                            <th>الرقم القومي</th>
                            <th>الهاتف</th>
                            <th>عمليات</th>
                        </tr>
                        <tr class="border-b hover:bg-slate-50 transition">
                            <td class="p-4 flex items-center gap-2">
                                <div class="w-8 h-8 bg-blue-100 rounded-full"></div>
                                محمود علي أحمد
                            </td>
                            <td>29905051234567</td>
                            <td>01142881682</td>
                            <td><button class="text-blue-600 text-sm">تعديل</button></td>
                        </tr>
                    </table>
                </div>
            </div>

            <div id="page-new-visit" class="page">
                <div class="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-lg">
                    <h3 class="text-xl font-bold mb-6 border-b pb-4">إصدار تصريح زيارة جديد</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium mb-1">ابحث بالرقم القومي</label>
                            <input type="text" placeholder="أدخل 14 رقم..." class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1">اسم النزيل المراد زيارته</label>
                            <select class="w-full p-3 border rounded-lg outline-none">
                                <option>وليد علي أحمد</option>
                                <option>صلاح محمد</option>
                            </select>
                        </div>
                        <button onclick="generateTicket()" class="w-full bg-slate-900 text-white py-4 rounded-xl font-bold hover:bg-slate-800 transition">إنشاء التصريح والـ QR Code</button>
                    </div>
                </div>
            </div>

            <div id="page-ticket" class="page">
                <div class="flex flex-col items-center">
                    <div class="bg-white border-2 border-slate-800 rounded-3xl p-8 w-80 text-center shadow-2xl relative">
                        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-slate-800 text-white px-4 py-1 rounded-full text-xs">ENTRY PASS</div>
                        <h4 class="font-bold text-lg mt-4">VMS System</h4>
                        <div class="my-6 bg-gray-100 p-4 inline-block rounded-xl border-2 border-dashed border-gray-300">
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=WALEED-PASS-99" alt="QR Code">
                        </div>
                        <div class="text-right space-y-2 text-sm">
                            <p><strong>الزائر:</strong> محمود علي أحمد</p>
                            <p><strong>النزيل:</strong> وليد علي</p>
                            <p><strong>التاريخ:</strong> 17 أبريل 2026</p>
                        </div>
                        <div class="mt-6 pt-4 border-t border-dashed">
                            <button onclick="window.print()" class="text-blue-600 font-bold">طباعة التصريح</button>
                        </div>
                    </div>
                    <button onclick="showPage('dashboard')" class="mt-8 text-slate-500 underline">العودة للرئيسية</button>
                </div>
            </div>

        </div>
    </main>

    <script>
        function showPage(pageId) {
            // إخفاء كل الصفحات
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            // إزالة الـ Active من الروابط
            document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
            document.querySelectorAll('.sidebar-link').forEach(l => l.classList.add('hover:bg-slate-800'));

            // إظهار الصفحة المطلوبة
            document.getElementById('page-' + pageId).classList.add('active');
            
            // تفعيل الرابط في السايدبار
            const activeLink = document.getElementById('link-' + pageId);
            if(activeLink) {
                activeLink.classList.add('active');
                activeLink.classList.remove('hover:bg-slate-800');
            }

            // تغيير العنوان
            const titles = {
                'dashboard': 'لوحة التحكم',
                'visitors': 'إدارة الزوار',
                'new-visit': 'إصدار زيارة جديدة',
                'ticket': 'تصريح الدخول الرقمي'
            };
            document.getElementById('page-title').innerText = titles[pageId];
        }

        function generateTicket() {
            // محاكاة تحميل
            const btn = event.target;
            btn.innerText = "جاري التوليد...";
            btn.disabled = true;
            
            setTimeout(() => {
                showPage('ticket');
                btn.innerText = "إنشاء التصريح والـ QR Code";
                btn.disabled = false;
            }, 1000);
        }
    </script>
</body>
</html>
